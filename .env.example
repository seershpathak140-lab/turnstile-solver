# Optional external Turnstile solver API. When both are set, /solve
# tries this first and falls back to the local Camoufox browser if it
# fails or times out. Leave empty to use the local browser only.
#
# The full request URL is built as:
#   ${TURNSTILE_FALLBACK_URL}?apikey=${TURNSTILE_FALLBACK_KEY}&url=<siteurl>&sitekey=<sitekey>
#
# Copy to .env and fill in. .env is gitignored — never commit secrets.
TURNSTILE_FALLBACK_URL=
TURNSTILE_FALLBACK_KEY=
