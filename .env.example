# Copy to .env and adjust. All values shown are defaults.

# HTTP service
PORT=9988
MAX_WORKERS=8
MAX_BODY_BYTES=65536
LOG_LEVEL=INFO

# API key gate. Empty = auth disabled (dev). When set, every path except
# /health requires the key via `X-API-Key` header or `?api_key=`.
API_KEY=

# Outbound egress proxy for the browser + byparr (e.g. WARP HTTP proxy).
# Empty = direct connection. WARP round-robins across instances on this one
# port — raise WARP_INSTANCES in docker-compose for per-request IP rotation.
SOLVER_PROXY=http://warp:8080

# Challenge proxy (Byparr / FlareSolverr-compatible). Delegates /solve-challenge.
CHALLENGE_PROXY_URL=http://byparr:8191
CHALLENGE_PROXY_KIND=byparr

# Camoufox: headed under Xvfb by default. true = headless (CF widgets may not mount).
HEADLESS=false
TS_PROFILE_DIR=/tmp/ts_profile
